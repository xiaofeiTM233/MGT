{
    "Default": {
        "timeout": 10000,
        "post_delay": 500,
        "focus": {
            "Node.Recognition.Succeeded": {
                "content": "{name} 识别成功"
            },
            "Node.Recognition.Failed": {
                "content": "❌ {name} 识别失败"
            }
        }
    },
    "TemplateMatch": {
        "recognition": "TemplateMatch",
        "threshold": 0.8,
        "order_by": "Score"
    }
}